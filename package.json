  "dependencies": {
    "axios": "^1.13.5",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "inquirer": "^13.2.4",
    "keytar": "^7.9.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
